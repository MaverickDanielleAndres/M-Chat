# M-Chat Environment Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Gemini AI API Key
# Get yours at https://aistudio.google.com/app/apikey
# Leave empty to use demo mode with pre-built responses
VITE_GEMINI_API_KEY=your-gemini-api-key

# Portfolio URL - Configurable link for the prompt limit modal
VITE_PORTFOLIO_URL=https://your-portfolio-url.com

# Contact URL - Configurable contact link
VITE_CONTACT_URL=https://your-contact-url.com
